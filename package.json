{
  "name": "unified-web-server",
  "version": "1.0.0",
  "description": "Central dashboard server for live motor/ESC test rig sensor data pushed from ESP32 modules",
  "type": "module",
  "private": true,
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "sim:module-a": "node tools/simulate-module.js --module esc_test_1 --name \"ESC Test Rig 1\" --hz 8 --channels force_n:N,temp_c:°C,rpm:rpm,voltage_v:V,current_a:A,power_w:W",
    "sim:module-b": "node tools/simulate-module.js --module load_cell_1 --name \"Load Cell 1\" --hz 5 --channels force_n:N,temp_c:°C"
  },
  "dependencies": {
    "express": "^4.19.2",
    "ws": "^8.18.0"
  }
}
