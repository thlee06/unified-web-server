{
  "name": "unified-web-server",
  "version": "1.0.0",
  "description": "Central dashboard server for ESP32 test-rig sensor data (diagnostic board, thrust stand)",
  "type": "module",
  "private": true,
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "sim:diag": "node tools/simulate-module.js --module diag_board_1 --name \"Diagnostic Board 1\" --hz 5 --channels a0_c:°C,a1_c:°C,a2_c:°C,a3_c:°C,a4_c:°C,a5_c:°C",
    "sim:thrust": "node tools/simulate-module.js --module thrust_stand_1 --name \"Thrust Stand 1\" --hz 5 --channels ch0:cts,ch1:cts,ch2:cts,ch3:cts"
  },
  "dependencies": {
    "express": "^4.19.2",
    "ws": "^8.18.0"
  }
}
